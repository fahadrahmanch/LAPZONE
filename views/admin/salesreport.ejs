<section class="content-main">
    <div class="content-header">
        <div>
            <h2 class="content-title card-title">Sales Report</h2>
        </div>
        <div>
            <button id="downloadPdf" class="btn btn-primary"><i class="text-muted material-icons md-post_add"></i>Download PDF</button>
            <button id="downloadExcel" class="btn btn-success"><i class="text-muted material-icons md-post_add"></i>Download Excel</button>
        </div>
    </div>

    <!-- Filter Form -->
    <div class="card mb-4">
        <header class="card-header">
            <h4 class="card-title">Filter Sales Report</h4>
            <form action="/admin/salesreport" method="GET">
                <div class="row align-items-end">
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Filter By</label>
                        <select id="filterType" name="period" class="form-select">
                            <option value="all" <%= period === "all" ? "selected" : "" %>>All Time</option>
                            <option value="daily" <%= period === "daily" ? "selected" : "" %>>Daily</option>
                            <option value="weekly" <%= period === "weekly" ? "selected" : "" %>>Weekly</option>
                            <option value="monthly" <%= period === "monthly" ? "selected" : "" %>>Monthly</option>
                            <option value="custom" <%= period === "custom" ? "selected" : "" %>>Custom Date Range</option>
                        </select>
                    </div>
                    
                    <div class="col-md-3 mb-3" id="customDateRange" style="display: <%= period === 'custom' ? 'block' : 'none' %>;">
                        <label class="form-label">Start Date</label>
                        <input type="date" id="startDate" name="startDate" value="<%= startDate %>" class="form-control">
                    </div>
                    
                    <div class="col-md-3 mb-3" id="customEndDate" style="display: <%= period === 'custom' ? 'block' : 'none' %>;">
                        <label class="form-label">End Date</label>
                        <input type="date" id="endDate" name="endDate" value="<%= endDate %>" class="form-control">
                    </div>

                    <div class="col-md-3 mb-3">
                        <button type="submit" class="btn btn-primary w-100">Generate Report</button>
                    </div>
                </div>
                <% if (typeof dateErr !== 'undefined' && dateErr) { %>
                    <div class="alert alert-danger mt-3"><%= dateErr %></div>
                <% } %>
            </form>
        </header>
    </div>

    <!-- Summary Cards -->
    <div class="row">
        <div class="col-lg-4">
            <div class="card card-body mb-4">
                <article class="icontext">
                    <span class="icon icon-sm rounded-circle bg-primary-light"><i class="text-primary material-icons md-monetization_on"></i></span>
                    <div class="text">
                        <h6 class="mb-1 card-title">Overall Sales Count</h6>
                        <span><%= count %></span>
                    </div>
                </article>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card card-body mb-4">
                <article class="icontext">
                    <span class="icon icon-sm rounded-circle bg-success-light"><i class="text-success material-icons md-local_shipping"></i></span>
                    <div class="text">
                        <h6 class="mb-1 card-title">Overall Order Amount</h6>
                        <span>₹<%= overallamount %></span>
                    </div>
                </article>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card card-body mb-4">
                <article class="icontext">
                    <span class="icon icon-sm rounded-circle bg-warning-light"><i class="text-warning material-icons md-qr_code"></i></span>
                    <div class="text">
                        <h6 class="mb-1 card-title">Overall Discount</h6>
                        <span>₹<%= overallDiscount %></span>
                    </div>
                </article>
            </div>
        </div>
    </div>

    <!-- Sales Table -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Customer</th>
                            <th>Products</th>
                            <th>Payment</th>
                            <th>Status</th>
                            <th>Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% orders.forEach((item) => { %>
                            <tr>
                                <td><%= item.createdOn %></td>
                                <td><%= item.userId?.name %></td>
                                <td>
                                    <% for (let key of item.orderedItems) { %>
                                        <%= key.Product.productName %><br>
                                    <% } %>
                                </td>
                                <td><%= item.paymentMethod %></td>
                                <td>
                                    <span class="badge rounded-pill <%= item.status === 'Delivered' ? 'alert-success' : item.status === 'Pending' ? 'alert-warning' : 'alert-danger' %>">
                                        <%= item.status %>
                                    </span>
                                </td>
                                <td>₹<%= item.finalAmount %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Pagination -->
    <div class="pagination-area mt-15 mb-50">
        <nav aria-label="Page navigation example">
            <ul class="pagination justify-content-start">
                <% if (currentPage > 1) { %>
                    <li class="page-item"><a class="page-link" href="?page=<%= currentPage - 1 %>&period=<%= period %>&startDate=<%= startDate %>&endDate=<%= endDate %>"><i class="material-icons md-chevron_left"></i></a></li>
                <% } %>
                
                <% 
                let startPage = Math.max(1, currentPage - 1);
                let endPage = Math.min(totalPages, startPage + 2);
                if (endPage - startPage < 2) startPage = Math.max(1, endPage - 2);
                
                for (let i = startPage; i <= endPage; i++) { %>
                    <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                        <a class="page-link" href="?page=<%= i %>&period=<%= period %>&startDate=<%= startDate %>&endDate=<%= endDate %>"><%= i %></a>
                    </li>
                <% } %>
                
                <% if (currentPage < totalPages) { %>
                    <li class="page-item"><a class="page-link" href="?page=<%= currentPage + 1 %>&period=<%= period %>&startDate=<%= startDate %>&endDate=<%= endDate %>"><i class="material-icons md-chevron_right"></i></a></li>
                <% } %>
            </ul>
        </nav>
    </div>
</section>

<script>
document.getElementById('filterType').addEventListener('change', function() {
    const customRange = document.getElementById('customDateRange');
    const customEndDate = document.getElementById('customEndDate');
    
    if (this.value === 'custom') {
        customRange.style.display = 'block';
        customEndDate.style.display = 'block';
    } else {
        customRange.style.display = 'none';
        customEndDate.style.display = 'none';
    }
});
</script>

