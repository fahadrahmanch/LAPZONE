<script>
   document.getElementById('downloadPdf').addEventListener("click", function (event) {
    event.preventDefault(); 

    const period = document.getElementById('filterType')?.value || "all";
    const startDate = document.getElementById("startDate")?.value || "";
    const endDate = document.getElementById("endDate")?.value || "";

    let url = `/admin/download-pdf?period=${period}`;
    if (startDate) url += `&startDate=${startDate}`;
    if (endDate) url += `&endDate=${endDate}`;

    window.location.href = url;
});
</script>
<script>
    document.getElementById('downloadExcel').addEventListener("click",function(){
        const period=document.getElementById('filterType')?.value||"all";
        const startDate=document.getElementById("startDate")?.value||""
        const endDate=document.getElementById("endDate")?.value||"";

        let url = `/admin/download-excel?period=${period}`;
        if (startDate) url += `&startDate=${startDate}`;
        if (endDate) url += `&endDate=${endDate}`;

        window.location.href = url;

    })
</script>











